# ============================================================
#  Salin file ini ke .env dan isi dengan nilai yang sebenarnya
#  cp .env.example .env
# ============================================================

# Dapatkan dari: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...   # anon / public key

# Service role key — RAHASIA, jangan expose ke client
# Dipakai hanya di server functions (registrations.functions.ts)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Token Fonnte untuk kirim WA otomatis saat approve pendaftaran
# Dapatkan dari: https://fonnte.com → Profile → Token
FONNTE_TOKEN=your-fonnte-token

# ⚠️  Setelah mengisi .env, restart dev server: npm run dev
